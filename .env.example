# z3rno-server local dev environment
#
# Copy this file to `.env` and adjust values as needed:
#   cp .env.example .env
#
# Docker Compose automatically picks up .env when running `docker compose up`.
# Do NOT commit your real .env — it's already in .gitignore.

# -----------------------------------------------------------------------------
# PostgreSQL (z3rno-postgres:17 with all extensions pre-installed)
# -----------------------------------------------------------------------------
POSTGRES_DB=z3rno
POSTGRES_USER=z3rno
POSTGRES_PASSWORD=z3rno_dev_password
POSTGRES_HOST_PORT=5432

# -----------------------------------------------------------------------------
# Valkey (used for cache, session state, rate-limit counters, Celery broker)
# -----------------------------------------------------------------------------
VALKEY_HOST_PORT=6379

# -----------------------------------------------------------------------------
# z3rno-server (FastAPI)
# -----------------------------------------------------------------------------
SERVER_HOST_PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# API key for local dev. The real z3rno-server will look up org_id via this.
# In production, API keys are stored hashed in the api_keys table. For local
# dev, any non-empty string works and maps to a bootstrap dev tenant.
Z3RNO_API_KEY=z3rno_sk_test_localdev

# -----------------------------------------------------------------------------
# Embedding provider (LiteLLM)
# -----------------------------------------------------------------------------
# MVP default is OpenAI text-embedding-3-small (1536 dims).
# Leave OPENAI_API_KEY empty for schema work that doesn't need real embeddings;
# the server will use a random-vector stub for development.
EMBEDDING_MODEL=text-embedding-3-small
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# Celery worker
# -----------------------------------------------------------------------------
CELERY_WORKER_CONCURRENCY=4

# -----------------------------------------------------------------------------
# Phase A — Forge pipeline (LLM-driven distillation)
# -----------------------------------------------------------------------------
# All Phase A surfaces are dormant unless DISTILL_ENABLED=true. When false:
#   - POST /v1/distill is not registered with the FastAPI app
#   - No Celery forge task is enqueued
#   - z3rno_core.distill modules import cleanly but never call out
# Existing /v1/memories endpoints are unaffected either way.
DISTILL_ENABLED=false

# LLM Gateway — provider-agnostic via LiteLLM. Reuses OPENAI_API_KEY when
# LLM_PROVIDER=openai unless an explicit LLM_API_KEY is set.
LLM_PROVIDER=openai
LLM_MODEL=openai/gpt-4o-mini
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=3

# Structured-output framework. "instructor" is the only supported value in
# Phase A; "baml" is reserved for a later phase.
STRUCTURED_OUTPUT_FRAMEWORK=instructor

# Forge tuning — chunk size in tokens, asyncio concurrency cap per job.
DISTILL_CHUNK_SIZE=1024
DISTILL_CHUNK_OVERLAP=128
DISTILL_MAX_CONCURRENCY=4
DISTILL_SUMMARY_STYLE=concise

# -----------------------------------------------------------------------------
# Phase B.1 — Ingestion surface (loaders + datasets + /v1/ingest)
# -----------------------------------------------------------------------------
# Master switch. With INGEST_ENABLED=false:
#   - /v1/ingest and /v1/datasets are not registered (404 / OpenAPI clean)
#   - the z3rno.ingest_run Celery task self-rejects messages
#   - existing endpoints behave byte-identically to pre-Phase-B
INGEST_ENABLED=false

# Storage backend for raw artifacts (uploaded files, fetched URLs).
# Phase B.1 ships "local" only; Phase B.2 adds "s3".
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=/var/lib/z3rno/artifacts

# Hard caps to prevent runaway extraction.
INGEST_MAX_FILE_BYTES=52428800   # 50 MB
INGEST_MAX_CSV_ROWS=10000

# When INGEST_AUTO_DISTILL=true (default), every successful ingest enqueues
# the Forge to distill the new memory IDs — that's the "drop in a PDF, get a
# graph" UX. Set to false if you only want the loader to create memories
# without LLM extraction.
INGEST_AUTO_DISTILL=true
INGEST_DEFAULT_CHUNK_SIZE=1024

# URL loader.
URL_FETCH_TIMEOUT_SECONDS=15
URL_ALLOWED_SCHEMES=http,https

# -----------------------------------------------------------------------------
# Phase B.2 — Multimodal + S3 + Tavily web search
# -----------------------------------------------------------------------------
# Each capability is independently gated.

# Multimodal (image + audio). Vision routes through litellm (OpenAI gpt-4o
# vision and compatible). Audio routes through litellm.atranscription (Whisper).
# MULTIMODAL_API_KEY falls back to OPENAI_API_KEY when empty.
MULTIMODAL_ENABLED=false
MULTIMODAL_VISION_MODEL=openai/gpt-4o-mini
MULTIMODAL_AUDIO_MODEL=whisper-1
MULTIMODAL_API_KEY=
MULTIMODAL_MAX_AUDIO_BYTES=26214400   # 25 MB (OpenAI cap)
MULTIMODAL_MAX_IMAGE_BYTES=20971520   # 20 MB

# S3 storage backend. Activated by setting STORAGE_BACKEND=s3 above.
# Leave S3_ACCESS_KEY_ID / S3_SECRET_ACCESS_KEY blank to use the default
# AWS credential chain (IAM role, ~/.aws/credentials, AWS_PROFILE, etc.).
# Set S3_ENDPOINT_URL for MinIO or other S3-compatible storage.
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_PREFIX=z3rno
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Tavily web search. Activated by setting TAVILY_API_KEY.
# When set, /v1/ingest/search is registered.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5

# Playwright fallback for JS-rendered URL pages.
# Requires `pip install 'z3rno-core[playwright]'` then `playwright install chromium`.
URL_PLAYWRIGHT_ENABLED=false
URL_PLAYWRIGHT_MIN_CHARS=200
URL_PLAYWRIGHT_TIMEOUT_SECONDS=30
